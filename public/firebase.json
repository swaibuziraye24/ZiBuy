{
  "hosting": {
    "public": "public",
    "rewrites": [
  {
    "source": "/blog/**",
    "function": "blogSeo"
  },
  {
    "source": "/product/**",
    "function": "productSeo"
  },
  {
    "source": "**",
    "destination": "/index.html"
  }
],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "DEPLOY_NOW.txt",
      "DEPLOYMENT.md",
      "README.md",
      "PREMIUM_ADS_SETUP.txt"
    ]
  },
  "functions": {
    "source": "functions"
  }
}
